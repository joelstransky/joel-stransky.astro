---
import { getEntry } from 'astro:content';

const general = await getEntry('settings','general');
---

<footer class="w-full bg-surface-primary border-t border-border-subtle transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-6 md:px-24 py-8 flex flex-col md:flex-row justify-between items-center gap-6">
    <!-- Copyright -->
    <p class="font-sans text-xs md:text-sm tracking-wider text-foreground-secondary uppercase order-2 md:order-1">
      &copy; {new Date().getFullYear()} JOEL STRANSKY. ALL RIGHTS RESERVED.
    </p>

    <!-- Links -->
    <nav class="flex items-center gap-6 font-sans text-xs md:text-sm font-normal text-foreground-secondary order-1 md:order-2">
      <a href="https://github.com/joelstransky" target="_blank" rel="noopener noreferrer" class="hover:text-foreground-primary transition-colors">GITHUB</a>
      <a href="https://linkedin.com/in/joelstransky" target="_blank" rel="noopener noreferrer" class="hover:text-foreground-primary transition-colors">LINKEDIN</a>
      <a href="https://twitter.com/joelstransky" target="_blank" rel="noopener noreferrer" class="hover:text-foreground-primary transition-colors">TWITTER</a>
      <a href="/cv" class="hover:text-foreground-primary transition-colors">CV</a>
    </nav>
  </div>
</footer>
