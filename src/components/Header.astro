---
import { getEntry } from 'astro:content';

const general = await getEntry('settings','general');
---

<header class="w-full bg-surface-primary border-b border-border-subtle transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-6 md:px-24 py-6 flex justify-between items-center">
    <!-- Logo -->
    <a href="/" class="text-xl md:text-2xl font-serif font-bold text-foreground-primary tracking-wide">
      JOEL STRANSKY
    </a>

    <!-- Right area (Desktop: visible, Mobile: hidden) -->
    <div class="hidden md:flex items-center gap-6">
      <nav class="flex items-center gap-6 font-sans text-sm font-normal text-foreground-secondary">
        <a href="/" class="hover:text-foreground-primary transition-colors">WORK</a>
        <a href="/about" class="hover:text-foreground-primary transition-colors">ABOUT</a>
        <a href="/cv" class="hover:text-foreground-primary transition-colors">CV</a>
      </nav>
      <div class="w-[1px] h-4 bg-border-subtle"></div>
      <div class="flex items-center gap-4">
        <!-- GitHub icon -->
        <a href="https://github.com/joelstransky" target="_blank" rel="noopener noreferrer" class="text-foreground-secondary hover:text-foreground-primary transition-colors" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <!-- Theme Toggle -->
        <button id="theme-toggle" class="text-foreground-secondary hover:text-foreground-primary transition-colors focus:outline-none" aria-label="Toggle Theme">
          <svg id="theme-toggle-light-icon" class="hidden dark:block" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
          <svg id="theme-toggle-dark-icon" class="block dark:hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
      </div>
    </div>

    <!-- Right area (Mobile: visible, Desktop: hidden) -->
    <div class="flex md:hidden items-center gap-4">
      <a href="https://github.com/joelstransky" target="_blank" rel="noopener noreferrer" class="text-foreground-secondary hover:text-foreground-primary transition-colors" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
      <button id="theme-toggle-mobile" class="text-foreground-secondary hover:text-foreground-primary transition-colors focus:outline-none" aria-label="Toggle Theme">
        <svg class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        <svg class="block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      </button>
      
      <!-- Mobile hamburger (for workspace navigation) -->
      <button id="mobile-menu-toggle" class="text-foreground-primary focus:outline-none" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </div>
  
  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden border-t border-border-subtle bg-surface-primary px-6 py-4 md:hidden font-sans text-base transition-colors duration-300">
    <nav class="flex flex-col gap-4 text-foreground-secondary">
      <a href="/" class="hover:text-foreground-primary transition-colors">WORK</a>
      <a href="/about" class="hover:text-foreground-primary transition-colors">ABOUT</a>
      <a href="/cv" class="hover:text-foreground-primary transition-colors">CV</a>
    </nav>
  </div>
</header>

<script>
  const initNav = () => {
    // Theme Toggle Functionality
    const themeToggles = [
      document.getElementById('theme-toggle'),
      document.getElementById('theme-toggle-mobile')
    ];

    themeToggles.forEach(toggle => {
      if (toggle) {
        // Clone to clear previous event listeners
        const clone = toggle.cloneNode(true);
        toggle.replaceWith(clone);
        
        clone.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          const newTheme = isDark ? 'dark' : 'light';
          document.cookie = `theme=${newTheme}; max-age=31536000; path=/; SameSite=Lax`;
        });
      }
    });

    // Mobile Menu Toggle
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuToggle && mobileMenu) {
      const clone = menuToggle.cloneNode(true);
      menuToggle.replaceWith(clone);

      clone.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });
    }
  };

  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
