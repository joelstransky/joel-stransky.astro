---
import { getCollection } from "astro:content";

import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import Hero from "../components/Hero.astro";

const allArticles = await getCollection("articles");
const articles = allArticles
  .filter((article) => !article.data.hidden)
  .sort((a, b) => {
    return b.data.date.getTime() - a.data.date.getTime();
  });

const appSlugs = [
  "bubble-park-beta",
  "kite-screen",
  "uh-office-of-title-ix",
  "uh-office-of-human-resources",
  "superb",
  "hopone",
  "nook-color-kids-reader",
  "the-living-glass-conversation",
  "cultureplayer",
  "dont-explode",
  "announcing-dont-explode"
];

const designSlugs = [
  "edvisors-design-exploration",
  "military-intelligence-instructor-badge",
  "the-endless-mural",
  "military-adaptive-sports-program",
  "the-early-years",
  "what-steve-jobs-meant-to-me"
];

const modelingSlugs = [
  "game-resolution-bust",
  "mio-bottle-product-shot",
  "lip-sync-animation-test",
  "the-griffon"
];

const appArticles = articles.filter(a => appSlugs.includes(a.slug));
const designArticles = articles.filter(a => designSlugs.includes(a.slug));
const modelingArticles = articles.filter(a => modelingSlugs.includes(a.slug));
---

<Layout title="Joel Stransky: Sr. Front End">
  <script>
    const masonry = () => {
      const portfolios = document.querySelectorAll(".portfolio");
      let column = 2;

      const responsive = [
        {
          breakpoint: 1024,
          column: 2,
        },
        {
          breakpoint: 768,
          column: 1,
        },
      ];

      const winWidth = window.innerWidth;

      for (let i = 0; i < responsive.length; i++) {
        if (winWidth <= responsive[i].breakpoint) {
          column = responsive[i].column;
        }
      }

      portfolios.forEach(portfolio => {
        if (column === 1) {
          const listElms = Array.from(portfolio.querySelectorAll("figure"));
          listElms.forEach((listElm: any) => {
            listElm.style.marginTop = "";
          });
          return;
        }

        const listElms = Array.from(portfolio.querySelectorAll("figure"));
        if (listElms.length === 0) {
          return;
        }

        listElms.forEach((listElm: any, index: number) => {
          listElm.style.marginTop = "";

          if (column > index) {
            return;
          }

          const topListElm = listElms[index - column];
          const topListElmPosi = topListElm.getBoundingClientRect().top;
          const topListHeight = getHeightAndMarginBottom(topListElm);
          const topListBottomPosi = topListElmPosi + topListHeight;
          const listElmPosi = listElm.getBoundingClientRect().top;
          let setPosi =
            listElmPosi.toFixed(0) - topListBottomPosi.toFixed(0) - 16;

          if (setPosi === 0) {
            return;
          }

          listElm.style.marginTop = "-" + setPosi + "px";
        });
      });
    };

    const getHeightAndMarginBottom = (elm: Element) => {
      const height = elm.getBoundingClientRect().height;
      const styles = getComputedStyle(elm);
      const bottom = parseFloat(styles.marginBottom);
      return height + bottom;
    };

    masonry();

    window.addEventListener("resize", () => {
      masonry();
    });
    document.addEventListener("DOMContentLoaded", () => {
      masonry();
    });
    document.addEventListener("astro:page-load", () => {
      masonry();
    });

    // Scroll-driven background interpolation for dark mode
    const initScrollBg = () => {
      const parseHex = (hex: string) => {
        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        return [r, g, b];
      };

      const darkColors = [
        parseHex('#060414'), // Top (0%)
        parseHex('#1a1040'), // App Eng (33%)
        parseHex('#091b36'), // Design Eng (66%)
        parseHex('#070519')  // 3D Modeling / Bottom (100%)
      ];

      const lightColors = [
        parseHex('#f4f2ff'), // Top (0%)
        parseHex('#f0ecff'), // App Eng (33%)
        parseHex('#edf4ff'), // Design Eng (66%)
        parseHex('#f2efff')  // 3D Modeling / Bottom (100%)
      ];

      const interpolateColors = (color1: number[], color2: number[], factor: number) => {
        const r = Math.round(color1[0] + (color2[0] - color1[0]) * factor);
        const g = Math.round(color1[1] + (color2[1] - color1[1]) * factor);
        const b = Math.round(color1[2] + (color2[2] - color1[2]) * factor);
        return `rgb(${r}, ${g}, ${b})`;
      };

      const updateBg = () => {
        const isDark = document.documentElement.classList.contains('dark');
        const colors = isDark ? darkColors : lightColors;

        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        if (maxScroll <= 0) return;

        const pct = window.scrollY / maxScroll;
        const clampedPct = Math.max(0, Math.min(1, pct));
        
        const segments = colors.length - 1;
        const position = clampedPct * segments;
        const index = Math.floor(position);
        const factor = position - index;

        let finalColor;
        if (index >= segments) {
          const c = colors[segments];
          finalColor = `rgb(${c[0]}, ${c[1]}, ${c[2]})`;
        } else {
          finalColor = interpolateColors(colors[index], colors[index + 1], factor);
        }

        document.documentElement.style.setProperty('--surface-primary', finalColor);
      };

      window.addEventListener('scroll', updateBg, { passive: true });
      updateBg();

      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.attributeName === 'class') {
            updateBg();
          }
        });
      });
      observer.observe(document.documentElement, { attributes: true });
    };

    initScrollBg();
    document.addEventListener('astro:page-load', initScrollBg);
  </script>

  <div class="relative bg-surface-primary transition-colors duration-300">
    <div class="mx-auto px-6 md:px-24 max-w-7xl pb-16">
      <Hero />
      
      <!-- Section 1: Application Engineering -->
      {appArticles.length > 0 && (
        <section class="mt-12 flex flex-col gap-8">
          <div class="flex flex-col gap-4 w-full">
            <div class="h-[1px] w-full bg-border-subtle transition-colors duration-300"></div>
            <h2 class="font-serif font-bold text-2xl md:text-3xl text-foreground-primary">
              Front End & Game Development
            </h2>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2 portfolio gap-8">
            {appArticles.map((article, index) => (
              <Card
                index={index + 1}
                slug={article.slug}
                title={article.data.title}
                image={article.data.image}
                tags={article.data.tag}
                body={article.body}
                section="app"
              />
            ))}
          </div>
        </section>
      )}

      <!-- Section 2: Design Engineering -->
      {designArticles.length > 0 && (
        <section class="mt-20 flex flex-col gap-8">
          <div class="flex flex-col gap-4 w-full">
            <div class="h-[1px] w-full bg-border-subtle transition-colors duration-300"></div>
            <h2 class="font-serif font-bold text-2xl md:text-3xl text-foreground-primary">
              Product Design & Digital Art
            </h2>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2 portfolio gap-8">
            {designArticles.map((article, index) => (
              <Card
                index={index + 1}
                slug={article.slug}
                title={article.data.title}
                image={article.data.image}
                tags={article.data.tag}
                body={article.body}
                section="design"
              />
            ))}
          </div>
        </section>
      )}

      <!-- Section 3: 3D Modeling -->
      {modelingArticles.length > 0 && (
        <section class="mt-20 flex flex-col gap-8">
          <div class="flex flex-col gap-4 w-full">
            <div class="h-[1px] w-full bg-border-subtle transition-colors duration-300"></div>
            <h2 class="font-serif font-bold text-2xl md:text-3xl text-foreground-primary">
              3D Character & Prop Art
            </h2>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2 portfolio gap-8">
            {modelingArticles.map((article, index) => (
              <Card
                index={index + 1}
                slug={article.slug}
                title={article.data.title}
                image={article.data.image}
                tags={article.data.tag}
                body={article.body}
                section="modeling"
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</Layout>
