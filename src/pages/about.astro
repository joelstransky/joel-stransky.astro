---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About - Joel Stransky">
  <main class="flex-grow flex items-center justify-center py-20 px-6 bg-surface-primary text-foreground-primary transition-colors duration-300">
    <div class="max-w-2xl w-full text-center">
      <h1 class="text-4xl font-serif font-bold mb-6">About Joel Stransky</h1>
      <div class="h-[1px] w-20 bg-accent-primary mx-auto mb-8"></div>
      <p class="text-lg text-foreground-secondary leading-relaxed font-sans mb-6">
        Hi, I'm Joel. I am a Creative Technologist passionate about bridge engineering, Roblox game development, complex 3D modeling, and frontend systems design.
      </p>
      <p class="text-lg text-foreground-secondary leading-relaxed font-sans">
        I love finding creative solutions to technical roadblocks, sifting through source code to solve deep puzzles, and building polished, performant systems.
      </p>
    </div>
  </main>
</Layout>
