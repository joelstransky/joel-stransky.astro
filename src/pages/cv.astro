---
import Layout from "../layouts/Layout.astro";
---

<Layout title="CV - Joel Stransky">
  <main class="flex-grow py-20 px-6 max-w-3xl mx-auto bg-surface-primary text-foreground-primary transition-colors duration-300">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-serif font-bold mb-4">Curriculum Vitae</h1>
      <p class="text-lg text-foreground-secondary font-sans">Joel Stransky</p>
      <div class="h-[1px] w-20 bg-accent-primary mx-auto mt-6"></div>
    </div>
    
    <div class="space-y-12 font-sans">
      <section>
        <h2 class="text-2xl font-serif font-bold mb-4 text-accent-primary">Skills</h2>
        <ul class="list-disc pl-5 space-y-2 text-foreground-secondary">
          <li><strong>Engineering & Architecture:</strong> Bridge engineering principles, 3D structural analysis.</li>
          <li><strong>Software Engineering:</strong> Frontend system design, React, Solid.js, TypeScript, HTML, CSS, JavaScript, PHP, WordPress.</li>
          <li><strong>3D & Game Development:</strong> ZBrush, Maya, Blender, Unity, C#, ActionScript 3, Roblox environment development.</li>
        </ul>
      </section>
      
      <section>
        <h2 class="text-2xl font-serif font-bold mb-4 text-accent-primary">Professional Focus</h2>
        <p class="text-foreground-secondary leading-relaxed">
          Bridging the gap between design engineering and technical software execution. Designing modular parent themes, generative vector brush algorithms, custom graphics engines, and physical-simulation-based game architectures.
        </p>
      </section>
    </div>
  </main>
</Layout>
