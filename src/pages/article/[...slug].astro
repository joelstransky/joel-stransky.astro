---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const blogEntries = await getCollection("articles");
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const blogEntries = await getCollection("articles");
const articles = blogEntries
  .filter(e => !e.data.hidden)
  .sort((a,b)=>{return b.data.date.getTime() - a.data.date.getTime()});

let previous:any, next:any;
const currentIndex = articles.findIndex(e=>e.slug===entry.slug)

previous = currentIndex > 0 && articles[currentIndex-1];

if(currentIndex < articles.length - 1) {
    next = articles[currentIndex+1]
}

const { Content } = await entry.render();
---

<Layout title={entry.data.title}>
  <div class="relative bg-surface-primary min-h-screen transition-colors duration-300">
    <div class="mx-auto px-6 md:px-24 max-w-4xl py-12">
      <!-- Back Link -->
      <a href="/" class="inline-flex items-center gap-2 text-sm font-sans font-bold text-accent-primary hover:text-foreground-primary transition-colors mb-8">
        &larr; Back to Portfolio
      </a>

      <!-- Featured Image -->
      <div class="relative w-full rounded border border-border-subtle bg-surface-secondary overflow-hidden aspect-[16/9]">
        <Image 
          width={1000} 
          height={562}
          src={entry.data.image} 
          alt={entry.data.title} 
          class="object-cover w-full h-full"
        />
      </div>

      <!-- Article Header -->
      <div class="relative w-full mt-10 mb-8">
        <p class="font-sans text-xs md:text-sm tracking-widest text-accent-primary font-medium uppercase mb-2">
          {entry.data.tag.map((t: string) => t.toUpperCase()).join(' • ')}
        </p>
        <h1 class="font-serif font-bold text-3xl md:text-5xl text-foreground-primary leading-tight mt-0 mb-4">
          {entry.data.title}
        </h1>
        <div class="h-[1px] w-full bg-border-subtle transition-colors duration-300 my-6"></div>
      </div>

      <!-- MDX Content -->
      <div class="prose dark:prose-invert max-w-none text-base md:text-lg text-foreground-secondary leading-relaxed font-sans mb-12">
        <Content />
      </div>

      <!-- Navigation Row -->
      <div class="h-[1px] w-full bg-border-subtle transition-colors duration-300 my-12"></div>
      <div class="flex justify-between items-center w-full font-sans text-sm text-foreground-secondary pb-12">
        {previous ? (
          <a href={`/article/${previous.slug}`} class="flex flex-col items-start gap-1 group no-underline">
            <span class="text-xs uppercase tracking-wider text-foreground-muted group-hover:text-accent-primary transition-colors">&larr; Previous Project</span>
            <span class="font-serif font-bold text-base md:text-lg text-foreground-primary group-hover:text-accent-primary transition-colors leading-tight">{previous.data.title}</span>
          </a>
        ) : <div></div>}
        {next ? (
          <a href={`/article/${next.slug}`} class="flex flex-col items-end gap-1 group no-underline">
            <span class="text-xs uppercase tracking-wider text-foreground-muted group-hover:text-accent-primary transition-colors">Next Project &rarr;</span>
            <span class="font-serif font-bold text-base md:text-lg text-foreground-primary group-hover:text-accent-primary transition-colors leading-tight">{next.data.title}</span>
          </a>
        ) : <div></div>}
      </div>
    </div>
  </div>
</Layout>
